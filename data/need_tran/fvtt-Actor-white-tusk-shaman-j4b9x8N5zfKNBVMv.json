    {
      "_id": "g5tvyXqpfFYvziOC",
      "name": "灵魂契约之身 (Spirit-Bonded Body)",
      "type": "feat",
      "system": {
        "source": {
          "custom": "",
          "book": "S&F",
          "page": "141",
          "license": "",
          "rules": "2014",
          "revision": 1
